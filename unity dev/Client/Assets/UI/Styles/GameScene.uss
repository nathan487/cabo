/* ============================================
   中文字体支持（Build 后显示中文必需）
   ============================================ */
/*
   字体文件位于：Assets/Resources/Fonts/ZCOOLKuaiLe.ttf
   站酷快乐体 - 开源中文字体

   使用 url() 而不是 resource() 以确保 Build 后正常工作
*/
* {
    -unity-font: url('project://database/Assets/Resources/Fonts/ZCOOLKuaiLe.ttf');
}

/* 备用方案：如果上面不工作，取消注释下面的代码并创建 Font Asset */
/*
* {
    -unity-font-definition: resource('Fonts/ZCOOLKuaiLe SDF');
}
*/

/* 根元素 */
.game-root {
    flex-grow: 1;
    background-color: rgb(25, 35, 55);
    justify-content: space-between;
    align-items: center;
}

/* HUD 顶部信息栏 */
.hud {
    width: 100%;
    height: 50px;
    background-color: rgba(10, 15, 25, 0.9);
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 5px;
}

.round-info {
    font-size: 18px;
    color: white;
    margin-right: 20px;
    -unity-font-style: bold;
}

.phase-text {
    font-size: 16px;
    color: rgb(255, 220, 100);
}

/* 玩家区域 */
.player-area {
    width: 90%;
    height: 120px;
    background-color: rgba(20, 25, 45, 0.85);
    border-radius: 8px;
    border-width: 2px;
    border-color: rgba(60, 70, 100, 0.8);
    padding: 10px;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
}

.opponent-area {
    margin-top: 10px;
}

.self-area {
    margin-bottom: 10px;
}

.player-name {
    font-size: 16px;
    color: white;
    min-width: 80px;
}

.player-score {
    font-size: 14px;
    color: rgb(200, 200, 255);
    min-width: 80px;
}

/* 卡牌容器 */
.cards-container {
    flex-direction: row;
    flex-grow: 1;
    justify-content: center;
    align-items: center;
}

/* 卡牌 */
.card {
    width: 60px;
    height: 85px;
    background-color: rgb(30, 45, 70);
    border-radius: 6px;
    border-width: 2px;
    border-color: rgb(50, 70, 100);
    margin: 0 5px;
    justify-content: center;
    align-items: center;
    font-size: 24px;
    color: white;
}

.card-back {
    background-color: rgb(50, 60, 80);
}

.card:hover {
    border-color: rgb(100, 140, 200);
    scale: 1.05;
}

/* 牌堆区域 */
.pile-area {
    width: 90%;
    height: 160px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
}

.pile {
    width: 100px;
    height: 120px;
    background-color: rgb(40, 55, 90);
    border-radius: 8px;
    border-width: 3px;
    border-color: rgb(60, 80, 120);
    margin: 0 20px;
    justify-content: center;
    align-items: center;
}

.draw-pile {
    border-color: rgb(40, 90, 140);
}

.discard-pile {
    border-color: rgb(75, 90, 125);
}

.pile-count,
.pile-value {
    font-size: 20px;
    color: white;
    -unity-font-style: bold;
}

/* 抽牌预览 */
.drawn-preview {
    position: absolute;
    width: 150px;
    height: 50px;
    background-color: rgba(50, 65, 90, 0.95);
    border-radius: 6px;
    border-width: 2px;
    border-color: rgb(100, 140, 200);
    justify-content: center;
    align-items: center;
    top: 50%;
    left: 50%;
    translate: -75px -25px;
}

.drawn-text {
    font-size: 18px;
    color: white;
}

/* 操作按钮面板 */
.action-panel {
    width: 95%;
    height: 50px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-bottom: 15px;
}

.action-btn {
    min-width: 80px;
    height: 40px;
    margin: 0 3px;
    border-radius: 5px;
    border-width: 2px;
    font-size: 14px;
    color: white;
}

.btn-primary {
    background-color: rgb(40, 120, 150);
    border-color: rgb(60, 140, 170);
}

.btn-primary:hover {
    background-color: rgb(50, 140, 180);
}

.btn-danger {
    background-color: rgb(130, 40, 50);
    border-color: rgb(150, 60, 70);
}

.btn-danger:hover {
    background-color: rgb(160, 50, 60);
}

.btn-secondary {
    background-color: rgb(75, 75, 75);
    border-color: rgb(100, 100, 100);
}

.btn-secondary:hover {
    background-color: rgb(90, 90, 90);
}

.btn-replace {
    min-width: 60px;
    background-color: rgb(100, 90, 40);
    border-color: rgb(120, 110, 60);
}

.btn-replace:hover {
    background-color: rgb(120, 110, 50);
}

/* 覆盖面板 */
.overlay-panel {
    position: absolute;
    width: 500px;
    height: 350px;
    background-color: rgba(15, 20, 40, 0.98);
    border-radius: 10px;
    border-width: 3px;
    border-color: rgb(80, 100, 140);
    justify-content: center;
    align-items: center;
    top: 50%;
    left: 50%;
    translate: -250px -175px;
    padding: 20px;
}

.overlay-text {
    font-size: 18px;
    color: white;
    white-space: normal;
    flex-grow: 1;
}

.overlay-btn {
    width: 160px;
    height: 44px;
    background-color: rgb(40, 130, 60);
    border-color: rgb(60, 150, 80);
    border-radius: 6px;
    border-width: 2px;
    font-size: 16px;
    color: white;
    margin-top: 20px;
}

.overlay-btn:hover {
    background-color: rgb(50, 150, 70);
}

/* 隐藏类 */
.hidden {
    display: none;
}

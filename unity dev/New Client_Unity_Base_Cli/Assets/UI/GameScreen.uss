Label {
    color: rgb(220, 220, 220);
    white-space: normal;
}

Button {
    color: rgb(235, 235, 245);
    background-color: rgb(50, 50, 80);
    border-radius: 6px;
    border-width: 1px;
    border-color: rgb(100, 100, 150);
    padding-top: 8px;
    padding-bottom: 8px;
    padding-left: 14px;
    padding-right: 14px;
    min-width: 104px;
    white-space: normal;
    -unity-text-align: middle-center;
}

TextField {
    color: rgb(25, 25, 35);
    white-space: normal;
}

TextField .unity-text-field__input {
    color: rgb(25, 25, 35);
    background-color: rgb(245, 245, 250);
}

TextField Label {
    color: rgb(220, 220, 220);
    white-space: normal;
}

Button:hover {
    background-color: rgb(70, 70, 110);
}

Button:disabled {
    background-color: rgb(40, 40, 50);
    color: rgb(100, 100, 100);
}

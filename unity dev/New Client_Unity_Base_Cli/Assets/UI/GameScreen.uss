:root {
    --cabo-bg-app: rgb(245, 230, 199);
    --cabo-bg-soft: rgb(252, 240, 212);
    --cabo-panel: rgb(255, 247, 222);
    --cabo-panel-alt: rgb(232, 212, 171);
    --cabo-panel-border: rgb(120, 89, 51);
    --cabo-table: rgb(158, 199, 145);
    --cabo-table-border: rgb(41, 87, 51);
    --cabo-text-primary: rgb(20, 31, 23);
    --cabo-text-secondary: rgb(56, 79, 59);
    --cabo-text-muted: rgb(92, 107, 87);
    --cabo-accent-peach: rgb(224, 107, 61);
    --cabo-accent-peach-hover: rgb(245, 138, 82);
    --cabo-accent-peach-border: rgb(120, 46, 23);
    --cabo-button-disabled: rgb(186, 176, 156);
    --cabo-button-disabled-border: rgb(110, 97, 79);
    --cabo-text-disabled: rgb(61, 56, 46);
    --cabo-input-bg: rgb(255, 252, 242);
    --cabo-input-border: rgb(97, 71, 41);
}

Label {
    color: var(--cabo-text-primary);
    white-space: normal;
}

Button {
    color: rgb(61, 38, 23);
    background-color: var(--cabo-accent-peach);
    border-radius: 6px;
    border-width: 1px;
    border-color: var(--cabo-accent-peach-border);
    padding-top: 8px;
    padding-bottom: 8px;
    padding-left: 14px;
    padding-right: 14px;
    min-width: 104px;
    white-space: normal;
    -unity-text-align: middle-center;
}

Button:hover {
    background-color: var(--cabo-accent-peach-hover);
}

Button:disabled {
    background-color: var(--cabo-button-disabled);
    border-color: var(--cabo-button-disabled-border);
    color: var(--cabo-text-disabled);
}

TextField {
    color: var(--cabo-text-primary);
    white-space: normal;
}

TextField .unity-text-field__input {
    color: var(--cabo-text-primary);
    background-color: var(--cabo-input-bg);
    border-color: var(--cabo-input-border);
}

TextField Label {
    color: var(--cabo-text-secondary);
    white-space: normal;
}

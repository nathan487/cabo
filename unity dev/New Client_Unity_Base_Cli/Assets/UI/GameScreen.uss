:root {
    --cabo-bg-app: rgb(245, 230, 199);
    --cabo-bg-soft: rgb(252, 240, 212);
    --cabo-panel: rgb(255, 247, 222);
    --cabo-panel-alt: rgb(232, 212, 171);
    --cabo-panel-border: rgb(99, 62, 75);
    --cabo-table: rgb(158, 199, 145);
    --cabo-table-border: rgb(41, 87, 51);
    --cabo-text-primary: rgb(56, 38, 51);
    --cabo-text-secondary: rgb(79, 64, 74);
    --cabo-text-muted: rgb(110, 94, 102);
    --cabo-accent-peach: rgb(217, 94, 122);
    --cabo-accent-peach-hover: rgb(235, 122, 146);
    --cabo-accent-peach-border: rgb(122, 46, 74);
    --cabo-button-disabled: rgb(186, 176, 156);
    --cabo-button-disabled-border: rgb(110, 97, 79);
    --cabo-text-disabled: rgb(61, 56, 46);
    --cabo-input-bg: rgb(255, 252, 242);
    --cabo-input-border: rgb(97, 71, 41);
}

Label {
    color: var(--cabo-text-primary);
    white-space: normal;
}

Button {
    color: rgb(255, 250, 238);
    background-color: var(--cabo-accent-peach);
    border-radius: 14px;
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 4px;
    border-left-width: 2px;
    border-color: var(--cabo-accent-peach-border);
    padding-top: 8px;
    padding-bottom: 8px;
    padding-left: 16px;
    padding-right: 16px;
    min-width: 104px;
    white-space: normal;
    -unity-text-align: middle-center;
}

Button.cabo-button-secondary {
    color: var(--cabo-text-primary);
    background-color: rgb(140, 199, 176);
    border-color: rgb(56, 107, 89);
}

Button.cabo-button-soft {
    color: var(--cabo-text-primary);
    background-color: rgb(243, 213, 143);
    border-color: rgb(138, 102, 51);
}

Button.cabo-button-danger {
    color: rgb(255, 255, 255);
    background-color: rgb(199, 81, 81);
    border-color: rgb(110, 41, 51);
}

Button:hover {
    background-color: var(--cabo-accent-peach-hover);
}

Button:disabled {
    background-color: var(--cabo-button-disabled);
    border-color: var(--cabo-button-disabled-border);
    color: var(--cabo-text-disabled);
}

TextField {
    color: var(--cabo-text-primary);
}

TextField .unity-base-text-field__input,
TextField .unity-text-field__input {
    color: var(--cabo-text-primary);
    background-color: var(--cabo-input-bg);
    border-radius: 12px;
    border-width: 2px;
    border-color: var(--cabo-input-border);
    padding-left: 12px;
    padding-right: 12px;
}

TextField:focus .unity-base-text-field__input,
TextField:focus .unity-text-field__input {
    border-color: rgb(57, 111, 75);
}

TextField Label {
    color: var(--cabo-text-secondary);
}
